"                        map_xcell2face_left1[pcellIdx+2] = iface;\n"
"                        map_xface2cell_upper[iface] = pcellIdx+2;\n"
"                        xface_level[pfaceIdx] = level[rncell];\n"
"                        xface_level[pfaceIdx+1] = level[rncell];\n"
