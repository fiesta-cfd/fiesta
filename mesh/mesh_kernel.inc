"    \n"
"   // Ensure the executing thread is not extraneous\n"
"   // Should not be necessary, should only be 1 thread executing\n"
"   if(giX >= max(nface[0], nface[1]))\n"
"      return;\n"
"\n"
"    int iface, pcellIdx, pfaceIdx, ifixupIdx;\n"
