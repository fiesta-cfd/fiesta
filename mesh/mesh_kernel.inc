"                           xsendIdx1[ifixupIdx] = map_xcell2face_right1[tncell];\n"
"                           xsendIdx2[ifixupIdx] = iface;\n"
"                        }\n"
"                    }\n"
"\n"
"                    i[pcellIdx] = i[rncell] - 1;\n"
"                    i[pcellIdx+1] = i[rncell] - 2;\n"
"                    i[pcellIdx+2] = i[lncell] + 1;\n"
