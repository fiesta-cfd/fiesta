"        level_right = level[rncell];\n"
"        if (!(lncell == nlft[lncell] || lncell == nbot[lncell] || lncell == ntop[lncell]) && \\\n"
"            !(rncell == nrht[rncell] || rncell == nbot[rncell] || rncell == ntop[rncell])) {\n"
"            if (level_left != level_right) {\n"
"                if (level_left < level_right) {\n"
