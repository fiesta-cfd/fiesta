"   int giX = tiX;\n"
"\n"
"   tile[tiX] = array[giX]; //XXX:IC?\n"
"\n"
"   for (giX += ntX; giX < isize; giX += ntX)\n"
"   {  if (array[giX] < tile[tiX]) tile[tiX] = giX; }\n"
"   barrier(CLK_LOCAL_MEM_FENCE);\n"
"\n"
"   for (int offset = ntX >> 1; offset > 32; offset >>= 1)\n"
