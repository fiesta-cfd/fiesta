"__kernel void copy_ghost_short_data_cl(\n"
"                          const int   ncells,           // 0\n"
"                          const int   nghost,           // 1\n"
"                 __global       short *data_buffer,     // 2\n"
"                 __global       short *data_buffer_add) // 3\n"
"{\n"
"   const unsigned int giX  = get_global_id(0);\n"
"\n"
"   if (giX >= nghost) return;\n"
"\n"
"   data_buffer[ncells+giX] = data_buffer_add[giX];\n"
"}\n"
